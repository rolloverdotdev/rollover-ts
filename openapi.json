            "type": "string"
          },
          "trial_end": {
            "format": "date-time",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          },
          "wallet_address": {
            "type": "string"
          }
        },
        "type": "object"
      }
