            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "org_id": {
            "format": "uuid",
            "type": "string"
          },
          "period_end": {
            "format": "date-time",
            "type": "string"
          },
          "period_start": {
            "format": "date-time",
            "type": "string"
          },
          "plan_id": {
            "format": "uuid",
            "type": "string"
          },
          "plan_name": {
            "type": "string"
          },
          "status": {
            "enum": [
              "active",
              "trialing",
              "expired"
