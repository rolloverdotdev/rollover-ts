            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "Feature": {
        "properties": {
          "credit_cost": {
            "type": "integer"
          },
          "feature_slug": {
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "limit_amount": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "overage_price": {
            "type": "string"
          },
          "plan_id": {
            "format": "uuid",
            "type": "string"
          },
          "reset_period": {
            "enum": [
              "billing_cycle",
              "daily",
              "weekly",
              "monthly"
            ],
            "type": "string"
          },
          "weight": {
            "type": "string"
          }
        },
        "required": [
          "feature_slug",
          "name"
        ],
        "type": "object"
      },
      "Invoice": {
        "properties": {
          "base_amount": {
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "overage_amount": {
            "type": "string"
          },
          "period_end": {
            "format": "date-time",
            "type": "string"
          },
          "period_start": {
            "format": "date-time",
            "type": "string"
          },
          "settled_at": {
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "subscription_id": {
            "format": "uuid",
            "type": "string"
          },
          "total_amount": {
            "type": "string"
          },
          "tx_hash": {
            "type": "string"
          },
          "wallet_address": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Plan": {
        "properties": {
          "billing_period": {
            "enum": [
              "monthly",
              "yearly"
            ],
            "type": "string"
          },
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "features": {
            "items": {
              "$ref": "#/components/schemas/Feature"
            },
            "type": "array"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "last_subscribed_at": {
            "format": "date-time",
            "type": "string"
          },
          "metadata": {
            "type": "object"
          },
          "mode": {
            "enum": [
              "test",
              "live"
            ],
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price_usdc": {
            "type": "string"
          },
          "setup_fee_usdc": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "sort_order": {
            "type": "integer"
          },
          "subscribers": {
            "type": "integer"
          },
          "trial_days": {
            "type": "integer"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "price_usdc",
          "billing_period"
        ],
        "type": "object"
      },
      "Subscription": {
        "properties": {
          "cancel_at_end": {
            "type": "boolean"
          },
