    "securitySchemes": {
      "apiKey": {
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      },
      "bearerJWT": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      },
      "walletJWT": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
